# Copy to .env and fill in values. (.env is gitignored)

# MySQL
DB_HOST=db.chanjao.com
DB_PORT=3306
DB_USER=wechat_monitor
DB_PASSWORD=CHANGE_ME
DB_NAME=wechat_monitor

# Cloudflare R2 (S3-compatible)
R2_BUCKET=wechat-monitor
R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_REGION=auto
# Optional key prefix inside the bucket
R2_KEY_PREFIX=wechat/

# WeChat local file root (optional; used for attachment upload)
# Example Windows path: C:\\Users\\Home\\Documents\\xwechat_files
WECHAT_FILES_ROOT=
# Optional: pin a specific account folder (e.g. wxid_...); if empty we auto-pick the newest.
WECHAT_WXID_DIR=

# Frontend notify (optional; if set, wcmon will POST hints when DB is updated)
NOTIFY_URL=https://wcmon.chanjao.com/api/notify
NOTIFY_TOKEN=CHANGE_ME
NOTIFY_SOURCE=wechat-monitor
NOTIFY_TIMEOUT_SECONDS=8

# Vision / Image AI (optional; used to describe received images and extract tracking numbers)
# Dashscope (OpenAI compatible) example:
# VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# VISION_MODEL=qwen3-vl-plus
VISION_BASE_URL=
VISION_MODEL=
VISION_API_KEY=CHANGE_ME
# Optional prompt override (defaults to shipment/tracking focused extraction)
VISION_IMAGE_PROMPT=
# Optional request timeout
VISION_TIMEOUT_SECONDS=45

# LINE monitor MySQL (independent from wcmon)
LINEMON_DB_HOST=db.chanjao.com
LINEMON_DB_PORT=3306
LINEMON_DB_USER=linemon
LINEMON_DB_PASSWORD=CHANGE_ME
LINEMON_DB_NAME=linemon

# Optional LINE-specific frontend notify overrides
LINEMON_NOTIFY_URL=
LINEMON_NOTIFY_TOKEN=
LINEMON_NOTIFY_SOURCE=line-monitor

