APP_NAME=Linemon Frontend
HOST=0.0.0.0
PORT=8080

# Linemon DB (same schema as line_capture.py writes to)
DB_HOST=db.chanjao.com
DB_PORT=3306
DB_USER=linemon
DB_PASSWORD=CHANGE_ME
DB_NAME=linemon

# Or use LINEMON_DB_* aliases instead of DB_*
# LINEMON_DB_HOST=db.chanjao.com
# LINEMON_DB_PORT=3306
# LINEMON_DB_USER=linemon
# LINEMON_DB_PASSWORD=CHANGE_ME
# LINEMON_DB_NAME=linemon

# Send-message upstream API (called by backend to avoid browser mixed-content issues)
SEND_API_BASE_URL=http://wootust.ddns.net:8788
SEND_API_TOKEN=
REQUEST_TIMEOUT_SECONDS=12

# Optional public base URL for attachment links
# R2_PUBLIC_BASE_URL=https://<public-domain-or-r2-gateway>
R2_PUBLIC_BASE_URL=

